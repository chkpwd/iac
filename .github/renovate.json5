{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  "flux": {
    "fileMatch": ["(^|/)kubernetes/.+\\.ya?ml$"]
  },
  "helm-values": {
    "fileMatch": ["(^|/)kubernetes/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["(^|/)kubernetes/.+\\.ya?ml$"]
  },
  "ansible": {
    "fileMatch": ["(^|/)ansible/.*?[^/]+\\.ya?ml(?:\\.j2)?$"]
  },
  "terraform": {
    "fileMatch": ["(^|/)terraform/.*?[^/]+\\.ya?ml$"]
  },
}
