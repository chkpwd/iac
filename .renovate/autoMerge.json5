{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto merge trusted container patches and minors",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch"],
      matchPackagePrefixes: [
        "ghcr.io/onedr0p",
        "ghcr.io/bjw-s",
        "ghcr.io/home-operations",
      ],
      ignoreTests: true,
    },
    {
      description: "Auto merge KPS minors and patches",
      matchDatasources: ["helm", "docker"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchDepNames: ["kube-prometheus-stack"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge trusted containers - anytime",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["ghcr.io/recyclarr/recyclarr"],
    },
    {
      description: "Auto-merge GitHub Actions",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge ansible collection/dep minors and patches",
      matchManagers: ["ansible-galaxy", "pip_requirements"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch"],
      minimumReleaseAge: "2 days",
      ignoreTests: false,
    },
    {
      description: "Auto-merge Terraform provider minors and patches",
      matchManagers: ["terraform"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch"],
      minimumReleaseAge: "3 days",
      ignoreTests: false,
    },
  ],
}
