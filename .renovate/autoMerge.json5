{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto merge container patches",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["patch"],
      matchPackagePrefixes: ["ghcr.io/onedr0p", "ghcr.io/bjw-s"],
      ignoreTests: true,
    },
    {
      description: "Auto merge KPS minors and patches",
      matchDatasources: ["helm", "docker"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchDepNames: ["kube-prometheus-stack"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge trusted containers - anytime",
      matchDatasources: ["docker"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: [
        "ghcr.io/home-operations/radarr",
        "ghcr.io/home-operations/sabnzbd",
        "ghcr.io/home-operations/sonarr",
        "ghcr.io/home-operations/tautulli",
        "ghcr.io/recyclarr/recyclarr",
      ],
    },
    {
      description: "Auto-merge GitHub Actions",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "pr",
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
  ],
}
